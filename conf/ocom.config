    }
    withName: BLAST_BLASTN {
        cpus   = { check_max( 16    * task.attempt, 'cpus'      ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'    ) }
        //memory = { check_max( 200.GB * task.attempt, 'memory'    ) }
        //tmp_time
        time   = 4.h
    }
