trace.overwrite   = true

params {
    skip_zotus        = true
    lca_with_fishbase = true
    use_bitwise       = true
    slurm_account     = 'pawsey1348'
    //slurm_account     = 'pawsey0964'
    queue_size        = 200
    dbname            = "curateddb"
    db2name           = "nt"

    dbfiles = [
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.ndb', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nhr', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nin', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nog', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nos', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.not', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nsq', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.ntf', \
        's3://oceanomics/Databases/eDNA/v1.0.1/v1.0.1.fasta.nto'
    ]
    aws.client.anonymous = true

    //aquamaps_db = 's3://oceanomics/Databases/eDNA/Aquamaps/am.db'
}

process {
    withName: CUTADAPT_TRIM_PRIMERS {
        cpus   = { check_max( 16    * task.attempt, 'cpus'      ) }
        memory = { check_max( 8.GB * task.attempt, 'memory'    ) }
        time   = 4.h
    }
    withName: CUTADAPT_TRIM_LEFTOVER_PRIMERS {
        cpus   = { check_max( 16    * task.attempt, 'cpus'      ) }
        memory = { check_max( 8.GB * task.attempt, 'memory'    ) }
        time   = 4.h
    }

    withName: FAIRE_CHECK {
        cpus   = { check_max( 1    * task.attempt, 'cpus'      ) }
        memory = { check_max( 6.GB * task.attempt, 'memory'    ) }
        time   = 4.h
    }
    withName: ADD_EXPERIMENTRUNMETADATA {
        cpus   = { check_max( 1    * task.attempt, 'cpus'      ) }
        memory = { check_max( 6.GB * task.attempt, 'memory'    ) }
        time   = 4.h
    }
    withName: CREATE_FAIRE_METADATA {
        cpus   = { check_max( 1    * task.attempt, 'cpus'      ) }
        memory = { check_max( 32.GB * task.attempt, 'memory'    ) }
        time   = 24.h
    }
